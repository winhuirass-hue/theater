<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
	<schema id="org.gnome.theater.plugins.pythonconsole" path="/org/gnome/theater/pythonconsole/" gettext-domain="@GETTEXT_PACKAGE@">
		<key name="rpdb2-password" type="s">
			<default>''</default>
			<summary>rpdb2 password</summary>
			<description>A password to protect the rpdb2 server for debugging theater from unauthorized remote access. If this is empty, a default of “theater” will be used.</description>
		</key>
	</schema>
</schemalist>
